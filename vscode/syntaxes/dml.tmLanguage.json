{
    "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/dmlLanguage.schema.json",
    "name": "Data Mapping Language",
    "scopeName": "source.dml",
    "patterns": [
        { "include": "#comments" },
        { "include": "#keywords" },
        { "include": "#types" },
        { "include": "#strings" },
        { "include": "#numbers" },
        { "include": "#operators" },
        { "include": "#functions" }
    ],
    "repository": {
        "comments": {
            "patterns": [
                {
                    "name": "comment.line.number-sign.dml",
                    "match": "#.*$"
                },
                {
                    "name": "comment.block.dml",
                    "begin": "/\\*",
                    "end": "\\*/"
                }
            ]
        },
        "keywords": {
            "patterns": [{
                "name": "keyword.control.dml",
                "match": "\\b(?i)(MAPPING|SOURCE|TARGET|RULES|COMPONENT|AGGREGATE|GROUP|BY|CLEANSE|VALIDATE|DISTINCT|VAR|CONST|MACRO|INCLUDE|IMPORT|IF|ELSE|TRY|CATCH|SWITCH|CASE|DEFAULT|LOOP|AS|MAP|BREAK|CONTINUE|SELECT|FILTER|OBJECT|TRANSFORM)\\b"
            }]
        },
        "types": {
            "patterns": [{
                "name": "storage.type.dml",
                "match": "\\b(?i)(XML|CSV|DB|EDI|JSON|STRING|INTEGER|DECIMAL|BOOLEAN|DATETIME)\\b"
            }]
        },
        "strings": {
            "name": "string.quoted.double.dml",
            "begin": "\"",
            "end": "\"",
            "patterns": [{
                "name": "constant.character.escape.dml",
                "match": "\\\\."
            }]
        },
        "numbers": {
            "name": "constant.numeric.dml",
            "match": "\\b\\d+(\\.\\d+)?\\b"
        },
        "operators": {
            "patterns": [
                { "name": "keyword.operator.dml", "match": "->|==|=|!=|>=|<=|>|<|\\+|-|\\*|/|:" }
            ]
        },
        "functions": {
            "patterns": [{
                "name": "entity.name.function.dml",
                "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*(?=\\s*\\()"
            }]
        }
    }
}
